{
  "name": "ai-builder-school",
  "version": "1.0.0",
  "private": true,
  "description": "AI Builder School — Korean-first practical AI learning platform for Codex/Claude Code workflows.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-content.ts",
    "new-lesson": "tsx scripts/new-lesson.ts",
    "eval": "tsx scripts/eval-lesson-quality.ts && tsx scripts/journey-route-check.ts",
    "eval:lessons": "tsx scripts/eval-lesson-quality.ts",
    "eval:routes": "tsx scripts/journey-route-check.ts",
    "eval:rubric": "tsx scripts/eval-lesson-rubric.ts",
    "check": "npm run lint && npm run typecheck && npm run validate && npm run build",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@types/mdx": "^2.0.13",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.1.0",
    "lefthook": "^2.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
